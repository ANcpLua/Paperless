# Vite dev server proxy target for `/api/*` requests.
# Defaults to the REST launch profile's `applicationUrl` (http://localhost:5057)
# if unset. Override locally if you run the REST API on a different port.
#
# Production (nginx-fronted) ignores this variable; the frontend calls
# relative /api/* paths and nginx handles routing.
VITE_API_URL=http://localhost:5057
