# ============================================
# Docker Images
# ============================================
POSTGRES_IMAGE=<set me>
RABBITMQ_IMAGE=<set me>
MINIO_IMAGE=<set me>
ELASTIC_IMAGE=<set me>
NGINX_IMAGE=<set me>
PAPERLESS_REST_IMAGE=<set me>
PAPERLESS_SERVICES_IMAGE=<set me>

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=<set me>
POSTGRES_USER=<set me>
POSTGRES_PASSWORD=<set me>

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_USERNAME=<set me>
RABBITMQ_PASSWORD=<set me>

# ============================================
# MinIO Configuration
# ============================================
MINIO_ROOT_USER=<set me>
MINIO_ROOT_PASSWORD=<set me>

# ============================================
# Elasticsearch Configuration
# ============================================
ELASTICSEARCH_DISCOVERY_TYPE=<set me>
ELASTICSEARCH_XPACK_SECURITY=<set me>
ES_JAVA_OPTS=<set me>

# ============================================
# Timezone
# ============================================
TZ=<set me>

# ============================================
# Connection Strings
# ============================================
CONNECTIONSTRINGS__PAPERLESSDB=<set me>
CONNECTIONSTRINGS__HANGFIRE=<set me>

# ============================================
# Storage Configuration
# ============================================
STORAGE__MINIO__ENDPOINT=<set me>
STORAGE__MINIO__ACCESSKEY=<set me>
STORAGE__MINIO__SECRETKEY=<set me>
STORAGE__MINIO__BUCKETNAME=<set me>
STORAGE__MINIO__USESSL=<set me>

# ============================================
# Messaging Configuration
# ============================================
RABBITMQ__URI=<set me>
ELASTICSEARCH__URI=<set me>
ELASTICSEARCH__DEFAULTINDEX=<set me>

# ============================================
# GenAI Configuration
# ============================================
GEMINI__APIKEY=<set me>
GEMINI__MODEL=<set me>
GEMINI__TIMEOUTSECONDS=<set me>

# ============================================
# Time Configuration
# ============================================
TIMEOFFSET__TIMEZONEID=<set me>

# ============================================
# Batch Processing Configuration
# ============================================
BATCH__INPUTPATH=<set me>
BATCH__ARCHIVEPATH=<set me>
BATCH__ERRORPATH=<set me>
BATCH__FILEPATTERN=<set me>
BATCH__CRONEXPRESSION=<set me>
BATCH__TIMEZONEID=<set me>

# ============================================
# ASP.NET Core Configuration
# ============================================
ASPNETCORE_URLS=<set me>

# ============================================
# Port Configuration
# ============================================
POSTGRES_PORT=<set me>
RABBITMQ_PORT=<set me>
RABBITMQ_MANAGEMENT_PORT=<set me>
MINIO_PORT=<set me>
MINIO_CONSOLE_PORT=<set me>
ELASTICSEARCH_PORT=<set me>
ELASTICSEARCH_TRANSPORT_PORT=<set me>
PAPERLESS_REST_PORT=<set me>
