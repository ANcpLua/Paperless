# Test-environment defaults loaded by xUnit integration fixtures via
# `Env.TraversePath().Load(".env.test")` in their static constructors.
#
# All values are placeholders intended ONLY for the test process.
# - Image tags match production for compatibility; they're public images.
# - Credentials are dummies; Testcontainers regenerates real ones at runtime
#   and overrides the connection-string env vars in fixture InitializeAsync.
# - URIs are parseable but point at localhost; non-container tests need the
#   URIs only to parse, not to actually connect (e.g. RabbitMqExtensionsTests
#   asserts DI registration, not message-bus behaviour).
# - GEMINI__APIKEY is a dummy literal. Tests that exercise the real GenAI
#   client must mock it; the value here only prevents null-bind failures.
#
# DO NOT put real secrets in this file. .env (production) and .env.local
# (developer) stay gitignored.

# Container images — pinned to match production majors (Postgres 17, RabbitMQ 4,
# MinIO latest, Elasticsearch 9.x). Bumping postgres 16 -> 17 closes the parity
# gap with the production compose stack so integration tests exercise the same
# migration / dialect surface the deployed REST + Services see.
POSTGRES_IMAGE=postgres:17-alpine
RABBITMQ_IMAGE=rabbitmq:4.3.0-management
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
ELASTIC_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:9.4.1

# Container credentials (placeholders; Testcontainers regenerates)
POSTGRES_DB=paperless
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Connection strings & URIs (overridden by SharedRestContainerFixture
# after containers start; only used for parseability where containers
# are absent)
CONNECTIONSTRINGS__PAPERLESSDB=Host=localhost;Port=5432;Database=paperless;Username=postgres;Password=postgres
CONNECTIONSTRINGS__HANGFIRE=Host=localhost;Port=5432;Database=paperless;Username=postgres;Password=postgres
RABBITMQ__URI=amqp://guest:guest@localhost:5672/
STORAGE__MINIO__ENDPOINT=localhost:9000
STORAGE__MINIO__ACCESSKEY=minioadmin
STORAGE__MINIO__SECRETKEY=minioadmin
STORAGE__MINIO__BUCKETNAME=paperless-test
STORAGE__MINIO__USESSL=false
ELASTICSEARCH__URI=http://localhost:9200
ELASTICSEARCH__DEFAULTINDEX=paperless-test

# Batch configuration (BatchOptions validator needs a valid IANA TZ id;
# null/empty triggers TimeZoneInfo.TryFindSystemTimeZoneById(null) -> throws)
BATCH__INPUTPATH=/tmp/paperless-test/input
BATCH__ARCHIVEPATH=/tmp/paperless-test/archive
BATCH__ERRORPATH=/tmp/paperless-test/error
BATCH__FILEPATTERN=*.xml
BATCH__CRONEXPRESSION=0 2 * * *
BATCH__TIMEZONEID=UTC
TIMEOFFSET__TIMEZONEID=UTC

# GenAI (mocked in tests; placeholder prevents null-bind failures)
GEMINI__APIKEY=test-gemini-key-placeholder
GEMINI__MODEL=gemini-2.5-flash
GEMINI__TIMEOUTSECONDS=30
GENAI__GEMINI__APIKEY=test-gemini-key-placeholder
GENAI__GEMINI__MODEL=gemini-2.5-flash

# ASP.NET / runtime
ASPNETCORE_URLS=http://+:5000
TZ=UTC
